{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "pocketarc/laravel-integrations-adapters",
    "description": "Adapter implementations for pocketarc/laravel-integrations.",
    "keywords": ["laravel", "integrations", "adapters"],
    "license": "MIT",
    "authors": [
        {
            "name": "Bruno Moreira",
            "email": "bruno.moreira@solmyr.com"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.3",
        "knplabs/github-api": "^3.16",
        "php-http/guzzle7-adapter": "^1.0",
        "pocketarc/laravel-integrations": "^1.5",
        "spatie/laravel-data": "^4.0",
        "thecodingmachine/safe": "^3.3",
        "zendesk/zendesk_api_client_php": "^4.1"
    },
    "require-dev": {
        "captainhook/captainhook": "^5.28",
        "ergebnis/phpstan-rules": "^2.6",
        "korbeil/phpstan-generic-rules": "^2.0",
        "larastan/larastan": "^3",
        "laravel/pint": "^1.24",
        "orchestra/testbench": "^10.0|^11.0",
        "php-http/mock-client": "^1.6",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^12.0",
        "shipmonk/phpstan-rules": "^4.1",
        "spaze/phpstan-disallowed-calls": "^4.9",
        "thecodingmachine/phpstan-safe-rule": "^1.4",
        "tomasvotruba/cognitive-complexity": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "Integrations\\Adapters\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Integrations\\Adapters\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
